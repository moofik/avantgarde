                    "width": "49%",
                    "effects": [
                      {
                        "type": "glitch",
                        "effect_trigger": "change",
                        "effect_amount": 0.22,
                        "effect_speed": 1.2
                      }
                    ]
                  }
                ]
              },
              {
                "type": "row",
                "id": "fx_knobs_row_bottom",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "knob",
                    "id": "damp",
