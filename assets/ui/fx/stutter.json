{
  "id": "fx_profile_stutter",
  "layout": {
    "type": "column",
    "gap": 1,
    "children": [
      {
        "type": "text",
        "id": "fx_meta",
        "bind": "status.fx.meta",
        "width": "100%"
      },
      {
        "type": "row",
        "id": "fx_split",
        "width": "100%",
        "gap": 2,
        "children": [
          {
            "type": "column",
            "id": "fx_controls_col",
            "width": "56%",
            "gap": 1,
            "children": [
              {
                "type": "row",
                "id": "st_knobs_row_top",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "knob",
                    "id": "st_wet",
                    "label": "WET",
                    "bind": "scene.fx.param.value.0",
                    "font": "gothic",
                    "font_size": 15,
                    "width": "49%",
                    "effects": [
                      {
                        "type": "glitch",
                        "effect_interval_ms": 10000,
                        "effect_amount": 0.22,
                        "effect_speed": 1.2
                      }
                    ]
                  },
                  {
                    "type": "knob",
                    "id": "st_rate",
                    "label": "RATE",
                    "bind": "scene.fx.param.value.1",
                    "font": "gothic",
                    "font_size": 15,
                    "width": "49%",
                    "effects": [
                      {
                        "type": "glitch",
                        "effect_interval_ms": 10000,
                        "effect_amount": 0.22,
                        "effect_speed": 1.2
                      }
                    ]
                  }
                ]
              },
              {
                "type": "row",
                "id": "st_knobs_row_mid",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "knob",
                    "id": "st_gate",
                    "label": "GATE",
                    "bind": "scene.fx.param.value.2",
                    "font": "gothic",
                    "font_size": 15,
                    "width": "49%",
                    "effects": [
                      {
                        "type": "glitch",
                        "effect_interval_ms": 20000,
                        "effect_amount": 0.22,
                        "effect_speed": 1.2
                      }
                    ]
                  },
                  {
                    "type": "knob",
                    "id": "st_retrig",
                    "label": "RETRIG",
                    "bind": "scene.fx.param.value.3",
                    "font": "gothic",
                    "font_size": 15,
                    "width": "49%",
                    "effects": [
                      {
                        "type": "glitch",
                        "effect_interval_ms": 20000,
                        "effect_amount": 0.22,
                        "effect_speed": 1.2
                      }
                    ]
                  }
                ]
              },
              {
                "type": "row",
                "id": "st_switch_row",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "switch",
                    "id": "st_retrig_mode",
                    "label": "RTRG STEP",
                    "bind": "scene.fx.param.value.3",
                    "options": ["OFF", "1", "2", "4", "8", "16"],
                    "font": "gothic",
                    "font_size": 14,
                    "width": "100%"
                  }
                ]
              }
            ]
          },
          {
            "type": "column",
            "id": "fx_visual_col",
            "width": "44%",
            "gap": 1,
            "children": [
              {
                "type": "anim_slot",
                "id": "st_anim",
                "bind": "fx.anim.current",
                "width": "100%",
                "height": 8
              }
            ]
          }
        ]
      }
    ]
  }
}
