{
  "id": "track_menu",
  "layout": {
    "type": "column",
    "style_ref": "@styles.frame.root",
    "padding": 0,
    "gap": 0,
    "width": 60,
    "height": 24,
    "children": [
      {
        "type": "statusbar",
        "id": "header_title",
        "text": "TRACK MENU",
        "bind": "status.scene.title",
        "style_ref": "@styles.header.title.default"
      },
      {
        "type": "separator",
        "id": "sep_top",
        "style_ref": "@styles.separator.default"
      },
      {
        "type": "list",
        "id": "menu_list",
        "height": "auto",
        "style_ref": "@styles.text.primary"
      },
      {
        "type": "separator",
        "id": "sep_bottom",
        "style_ref": "@styles.separator.default"
      },
      {
        "type": "text",
        "id": "action_status",
        "bind": "status.action",
        "style_ref": "@styles.footer.action"
      },
      {
        "type": "text",
        "id": "keys_hint",
        "text": " keys [F5/F6 select] [F1 apply] [n seq] [shift+n pattern] [esc back] ",
        "bind": "status.keys",
        "style_ref": "@styles.footer.keys"
      }
    ]
  }
}
