{
  "id": "fx_profile_stutter",
  "layout": {
    "type": "column",
    "gap": 1,
    "children": [
      {
        "type": "text",
        "id": "fx_meta",
        "bind": "status.fx.meta",
        "style_ref": "@styles.fx.meta"
      },
      {
        "type": "row",
        "id": "fx_split",
        "width": "100%",
        "gap": 2,
        "children": [
          {
            "type": "column",
            "id": "fx_controls_col",
            "width": "56%",
            "gap": 1,
            "children": [
              {
                "type": "row",
                "id": "st_knobs_row_top",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "knob",
                    "id": "st_wet",
                    "label": "WET",
                    "bind": "fx.selected.param.0",
                    "target": "param.fx.selected.0",
                    "style_ref": "@styles.fx.knob.base",
                    "width": "49%",
                    "effects": [
                      { "preset": "@effects.glitch.knob.time_fast" }
                    ]
                  },
                  {
                    "type": "knob",
                    "id": "st_rate",
                    "label": "RATE",
                    "bind": "fx.selected.param.1",
                    "target": "param.fx.selected.1",
                    "style_ref": "@styles.fx.knob.base",
                    "width": "49%",
                    "effects": [
                      { "preset": "@effects.glitch.knob.time_fast" }
                    ]
                  }
                ]
              },
              {
                "type": "row",
                "id": "st_knobs_row_mid",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "knob",
                    "id": "st_gate",
                    "label": "GATE",
                    "bind": "fx.selected.param.2",
                    "target": "param.fx.selected.2",
                    "style_ref": "@styles.fx.knob.base",
                    "width": "49%",
                    "effects": [
                      { "preset": "@effects.glitch.knob.time_slow" }
                    ]
                  },
                  {
                    "type": "knob",
                    "id": "st_retrig",
                    "label": "RETRIG",
                    "bind": "fx.selected.param.3",
                    "target": "param.fx.selected.3",
                    "style_ref": "@styles.fx.knob.base",
                    "width": "49%",
                    "effects": [
                      { "preset": "@effects.glitch.knob.time_slow" }
                    ]
                  }
                ]
              },
              {
                "type": "row",
                "id": "st_switch_row",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "switch",
                    "id": "st_retrig_mode",
                    "label": "RTRG STEP",
                    "bind": "fx.selected.param.3",
                    "target": "param.fx.selected.3",
                    "options": ["OFF", "1", "2", "4", "8", "16"],
                    "style_ref": "@styles.fx.switch.base",
                    "width": "100%"
                  }
                ]
              }
            ]
          },
          {
            "type": "column",
            "id": "fx_visual_col",
            "width": "44%",
            "gap": 1,
            "children": [
              {
                "type": "anim_slot",
                "id": "st_anim",
                "bind": "fx.anim.current",
                "style_ref": "@styles.fx.animslot",
                "width": "100%",
                "height": 8
              }
            ]
          }
        ]
      }
    ]
  }
}
