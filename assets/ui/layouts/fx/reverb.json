{
  "id": "fx_profile_reverb",
  "layout": {
    "type": "column",
    "padding": 0,
    "gap": 1,
    "children": [
      {
        "type": "text",
        "id": "fx_meta",
        "bind": "status.fx.meta",
        "style_ref": "@styles.fx.meta"
      },
      {
        "type": "row",
        "id": "fx_split",
        "width": "100%",
        "gap": 2,
        "children": [
          {
            "type": "column",
            "id": "fx_controls_col",
            "width": "56%",
            "gap": 1,
            "children": [
              {
                "type": "row",
                "id": "fx_knobs_row_top",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "knob",
                    "id": "wet",
                    "label": "WET",
                    "bind": "fx.selected.param.0",
                    "target": "param.fx.selected.0",
                    "style_ref": ["@styles.fx.knob.base", "@styles.fx.knob.glitch_on_change"],
                    "width": "49%"
                  },
                  {
                    "type": "knob",
                    "id": "room",
                    "label": "ROOM",
                    "bind": "fx.selected.param.1",
                    "target": "param.fx.selected.1",
                    "style_ref": ["@styles.fx.knob.base", "@styles.fx.knob.glitch_on_change"],
                    "width": "49%"
                  }
                ]
              },
              {
                "type": "row",
                "id": "fx_knobs_row_bottom",
                "width": "100%",
                "gap": 1,
                "children": [
                  {
                    "type": "knob",
                    "id": "damp",
                    "label": "DAMP",
                    "bind": "fx.selected.param.2",
                    "target": "param.fx.selected.2",
                    "style_ref": ["@styles.fx.knob.base", "@styles.fx.knob.glitch_on_change"],
                    "width": "49%"
                  },
                  {
                    "type": "knob",
                    "id": "width",
                    "label": "WIDTH",
                    "bind": "fx.selected.param.3",
                    "target": "param.fx.selected.3",
                    "style_ref": ["@styles.fx.knob.base", "@styles.fx.knob.glitch_on_change"],
                    "width": "49%"
                  }
                ]
              }
            ]
          },
          {
            "type": "column",
            "id": "fx_visual_col",
            "width": "44%",
            "gap": 1,
            "children": [
              {
                "type": "anim_slot",
                "id": "fx_anim",
                "width": "100%",
                "height": 8,
                "bind": "fx.anim.reverb",
                "style_ref": "@styles.fx.animslot"
              }
            ]
          }
        ]
      }
    ]
  }
}
