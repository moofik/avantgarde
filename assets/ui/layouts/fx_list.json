{
  "id": "fx_list",
  "layout": {
    "type": "column",
    "style_ref": "@styles.frame.root",
    "padding": 0,
    "gap": 0,
    "width": 60,
    "height": 24,
    "children": [
      {
        "type": "statusbar",
        "id": "header_title",
        "text": "FX LIST",
        "bind": "status.scene.title",
        "style_ref": "@styles.header.title.default",
        "effects": [
          {
            "preset": "@effects.glitch.header.fxlist"
          }
        ]
      },
      {
        "type": "separator",
        "id": "sep_top",
        "style_ref": "@styles.separator.default"
      },
      {
        "type": "text",
        "id": "fx_type_status",
        "text": " quick: F1 edit/add | F7 bypass | F8 remove ",
        "style_ref": "@styles.text.secondary"
      },
      {
        "type": "list",
        "id": "fx_list",
        "height": "auto",
        "style_ref": "@styles.text.primary"
      },
      {
        "type": "separator",
        "id": "sep_bottom",
        "style_ref": "@styles.separator.default"
      },
      {
        "type": "text",
        "id": "action_status",
        "bind": "status.action",
        "style_ref": "@styles.footer.action"
      },
      {
        "type": "text",
        "id": "keys_hint",
        "text": " keys [F5/F6 slot] [F1 apply] [F7 bypass] [F8 remove] [esc] ",
        "bind": "status.keys",
        "style_ref": "@styles.footer.keys"
      }
    ]
  }
}
